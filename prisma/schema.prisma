// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Better Auth Models ──────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  hospitals     Hospital[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Application Models ──────────────────────────────

model Hospital {
  id             String          @id @default(cuid())
  nameAr         String
  nameEn         String
  email          String          @unique
  address        String?
  phone          String?
  type           String?         // 'public' | 'private'

  latitude       Float?
  longitude      Float?

  bedsGeneral    Int             @default(0)
  bedsIcu        Int             @default(0)
  bedsEmergency  Int             @default(0)

  lastUpdate     DateTime        @default(now())

  adminId        String
  admin          User            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  history        UpdateHistory[]
}

model UpdateHistory {
  id             String          @id @default(cuid())
  hospitalId     String
  hospital       Hospital        @relation(fields: [hospitalId], references: [id])
  bedsGeneral    Int
  bedsIcu        Int
  bedsEmergency  Int
  updatedAt      DateTime        @default(now())
  updatedBy      String          // e.g. "Admin"
}
